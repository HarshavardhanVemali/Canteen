# Django Core Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*
DATABASE_URL=sqlite:///db.sqlite3

# Google OAuth2
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-client-id
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-client-secret

# Email Settings (Gmail SMTP)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Payment Gateways (PhonePe)
PHONEPE_MERCHANT_ID=PHONEPEPGUAT
PHONEPE_MERCHANT_KEY=your-phonepe-merchant-key
PHONEPE_SALT_INDEX=1
PHONEPE_SALT_KEY=1

# Payment Gateways (PayU)
PAYU_MERCHANT_KEY=your-payu-key
PAYU_MERCHANT_SALT=your-payu-salt
PAYU_CLIENT_ID=your-payu-client-id
PAYU_CLIENT_SECRET=your-payu-client-secret

# Firebase
FIREBASE_CREDENTIALS_PATH=path/to/your/firebase-adminsdk.json
